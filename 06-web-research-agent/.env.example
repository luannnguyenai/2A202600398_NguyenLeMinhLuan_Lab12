# Copy to .env.local before running locally.
# Do not commit .env.local.

HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

APP_NAME=Web Research Agent
APP_VERSION=1.0.0

OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-5-mini
SERPER_API_KEY=

AGENT_API_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=604800
MAX_HISTORY_MESSAGES=12

RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0

SEARCH_RESULTS_LIMIT=5
FETCH_MAX_MARKDOWN_CHARS=8000
MAX_TOOL_ROUNDS=4
CRAWLER_PAGE_TIMEOUT_MS=20000

INPUT_COST_PER_1K_TOKENS_USD=0.00025
OUTPUT_COST_PER_1K_TOKENS_USD=0.002
SEARCH_TOOL_COST_USD=0.001
FETCH_TOOL_COST_USD=0.002
